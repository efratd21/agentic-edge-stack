# Copy to .env and adjust as needed. Defaults match a local Ollama install.

# Ollama server (OpenAI-compatible endpoint lives under /v1)
OLLAMA_HOST=http://localhost:11434

# Models (pull with: ollama pull <model>)
# Chat/agent model must support tool-calling for the Part 3 agent
# (gemma3:1b does NOT; llama3.2:3b does).
MODEL_NAME=llama3.2:3b
EMBED_MODEL=nomic-embed-text
EMBED_DIM=768

# RAG retrieval
TOP_K=3
CHUNK_SIZE=1800
CHUNK_OVERLAP=200
RELEVANCE_THRESHOLD=0.6

# Paths
CORPUS_DIR=data/corpus
RAG_LOG=logs/rag_retrieval.log
AGENT_TRACE_LOG=logs/agent_trace.log
