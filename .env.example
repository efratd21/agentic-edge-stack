# Copy to .env and adjust as needed. Defaults match a local Ollama install.

# Ollama server (OpenAI-compatible endpoint lives under /v1)
OLLAMA_HOST=http://localhost:11434

# Models (pull with: ollama pull gemma3:1b && ollama pull nomic-embed-text)
MODEL_NAME=gemma3:1b
EMBED_MODEL=nomic-embed-text
EMBED_DIM=768

# RAG retrieval
TOP_K=3
CHUNK_SIZE=1800
CHUNK_OVERLAP=200

# Paths
CORPUS_DIR=data/corpus
RAG_LOG=logs/rag_retrieval.log
